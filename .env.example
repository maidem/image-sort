# Pfad zur SQLite-Datenbank im Container/Server
DATABASE_PATH=/data/app.db

# Passwort für den Admin-Bereich (Pläne/Trainer/Gruppen verwalten).
# WENN LEER: alle Admin-Endpunkte sind deaktiviert.
ADMIN_PASSWORD=

# Geheimer Schlüssel zum Signieren der Admin-Session-Cookies.
# Generieren z. B. mit: openssl rand -hex 32
SESSION_SECRET=
